{
  "name": "@myceliumhq/plugin-core",
  "private": true,
  "displayName": "mycelium",
  "description": "Mycelium is a hierarchical note taking tool that grows as you do.",
  "publisher": "mycelium",
  "version": "0.124.0",
  "sponsor": {
    "url": "https://accounts.mycelium.so/account/subscribe"
  },
  "engines": {
    "vscode": "^1.77.0"
  },
  "categories": [
    "Other"
  ],
  "installConfig": {
    "hoistingLimits": "none"
  },
  "keywords": [
    "second brain",
    "markdown",
    "roam",
    "notes",
    "schema"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/src/extension.js",
  "browser": "./dist/web/extension.js",
  "extensionPack": [
    "mycelium.mycelium-paste-image"
  ],
  "contributes": {
    "languages": [
      {
        "id": "markdown",
        "extensions": [
          ".md"
        ],
        "aliases": [
          "markdown"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "viewsWelcome": [
      {
        "view": "mycelium.backlinks",
        "contents": "There are no backlinks to this note."
      },
      {
        "view": "mycelium.recent-workspaces",
        "contents": "No recent workspaces detected. If this is your first time using Mycelium, [try out our tutorial workspace](command:mycelium.launchTutorialWorkspace?%7B%22invocationPoint%22%3A%22RecentWorkspacesPanel%22%7D)."
      },
      {
        "view": "mycelium.treeView",
        "contents": "First open a Mycelium note to see the tree view."
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mycelium-view",
          "title": "Mycelium",
          "icon": "media/icons/mycelium-activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "mycelium.sample",
          "name": "Sample View",
          "type": "webview",
          "when": "mycelium:devMode"
        }
      ],
      "mycelium-view": [
        {
          "id": "mycelium.tip-of-the-day",
          "name": "Tip of the Day",
          "when": "mycelium:pluginActive && shellExecutionSupported",
          "type": "webview"
        },
        {
          "id": "mycelium.backlinks",
          "name": "Backlinks",
          "when": "mycelium:pluginActive && shellExecutionSupported"
        },
        {
          "id": "mycelium.treeView",
          "name": "Tree View",
          "when": "mycelium:pluginActive",
          "icon": "media/icons/mycelium-vscode.svg"
        },
        {
          "id": "mycelium.lookup-view",
          "name": "Lookup View",
          "type": "webview",
          "when": "mycelium:pluginActive && mycelium:noteLookupActive && mycelium:shouldShowLookupView"
        },
        {
          "id": "mycelium.calendar-view",
          "name": "Calendar View",
          "type": "webview",
          "when": "mycelium:pluginActive && shellExecutionSupported"
        },
        {
          "id": "mycelium.recent-workspaces",
          "name": "Recent Mycelium Workspaces",
          "when": "!mycelium:pluginActive && shellExecutionSupported"
        },
        {
          "id": "mycelium.help-and-feedback",
          "name": "Help and Feedback",
          "when": "shellExecutionSupported"
        },
        {
          "id": "mycelium.graph-panel",
          "name": "Graph Panel",
          "type": "webview",
          "when": "mycelium:pluginActive && shellExecutionSupported"
        }
      ]
    },
    "categories": [
      "Other"
    ],
